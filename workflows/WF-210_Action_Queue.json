    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nUPDATE ai.action_queue\nSET status      = 'done',\n    resolved_at = NOW(),\n    payload     = COALESCE(payload, '{}'::jsonb) || jsonb_build_object('result', $2)\nWHERE id = $1\nRETURNING id, status, resolved_at;\n",
        "options": {
