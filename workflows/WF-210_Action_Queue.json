    },
    {
      "parameters": {
        "jsCode": "\nconst q = $input.first().json.query || {};\nreturn [{ json: { params: [\n  q.status || 'pending,auto',\n  parseInt(q.limit || '100', 10)\n] } }];\n"
      },
      "id": "code-9c5c3b5b",
      "name": "Prep LIST params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        280
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nSELECT json_agg(t ORDER BY created_at DESC) AS result FROM (\n  SELECT id, agent_name, action_type, preview, payload,\n         status, approval_required, sla_deadline, why_now,\n         ceo_comment, created_at, resolved_at,\n         (sla_deadline IS NOT NULL AND sla_deadline < NOW()) AS is_overdue\n  FROM ai.action_queue\n  WHERE status = ANY (string_to_array($1, ','))\n  ORDER BY\n    CASE WHEN sla_deadline IS NOT NULL AND sla_deadline < NOW() THEN 0 ELSE 1 END,\n    created_at DESC\n  LIMIT $2\n) t;\n",
        "options": {
          "queryReplacement": "={{ $json.params }}"
        }
      },
      "id": "pg-3217e834",
      "name": "PG · List queue",
