    {
      "parameters": {
        "jsCode": "\nconst b = $input.first().json.body || {};\nlet slaDeadline = null;\nif (b.sla) {\n  const m = String(b.sla).match(/^(\\d+)\\s*(second|minute|min|hour|day|week|month)/i);\n  if (m) {\n    const n = parseInt(m[1], 10);\n    const unit = m[2].toLowerCase();\n    const ms = unit.startsWith('sec') ? n*1000\n             : unit.startsWith('min') ? n*60000\n             : unit.startsWith('hour') ? n*3600000\n             : unit.startsWith('day') ? n*86400000\n             : unit.startsWith('week') ? n*7*86400000\n             : unit.startsWith('month') ? n*30*86400000\n             : 0;\n    if (ms > 0) slaDeadline = new Date(Date.now() + ms).toISOString();\n  }\n}\nreturn [{ json: { params: [\n  b.agent_name || 'unknown',\n  b.action_type || 'unknown',\n  JSON.stringify(b.payload || {}),\n  b.preview || '',\n  b.approval_required === false ? false : true,\n  slaDeadline,\n  b.why_now || ''\n] } }];\n"
      },
      "id": "code-51031158",
      "name": "Prep ADD params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        100
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nINSERT INTO ai.action_queue (\n  agent_name, action_type, payload, preview, status,\n  approval_required, sla_deadline, why_now\n) VALUES (\n  $1, $2, $3::jsonb, $4,\n  CASE WHEN $5::boolean THEN 'pending' ELSE 'auto' END,\n  $5::boolean,\n  $6::timestamptz,\n  $7\n)\nRETURNING id, status, created_at, sla_deadline;\n",
        "options": {
          "queryReplacement": "={{ $json.params }}"
        }
      },
