      "parameters": {
        "jsCode": "\nconst b = $input.first().json.body || {};\nreturn [{ json: { params: [\n  parseInt(b.id, 10),\n  b.decision || 'approve',\n  b.comment || ''\n] } }];\n"
      },
      "id": "code-31ad8886",
      "name": "Prep DECIDE params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        460
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nUPDATE ai.action_queue\nSET status      = CASE WHEN $2 = 'approve' THEN 'approved'\n                       WHEN $2 = 'reject'  THEN 'rejected'\n                       ELSE status END,\n    ceo_comment = NULLIF($3, ''),\n    resolved_at = NOW()\nWHERE id = $1\nRETURNING id, status, resolved_at, ceo_comment;\n",
        "options": {
          "queryReplacement": "={{ $json.params }}"
        }
      },
