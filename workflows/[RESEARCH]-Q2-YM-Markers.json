    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nSELECT\n  CASE\n    WHEN external_order_id IS NULL THEN 'NULL'\n    WHEN external_order_id = 'VIRTUAL' THEN 'VIRTUAL'\n    WHEN external_order_id LIKE 'KINGUIN_%' THEN 'KINGUIN_xxx'\n    WHEN external_order_id LIKE 'YM_%' THEN 'YM_xxx'\n    WHEN external_order_id LIKE 'FRAGSTORE_%' THEN 'FRAGSTORE_xxx'\n    ELSE 'OTHER: ' || LEFT(external_order_id, 30)\n  END as pattern,\n  COUNT(*) as cnt\nFROM marketplace_order\nWHERE created_at > NOW() - INTERVAL '90 days'\nGROUP BY 1 ORDER BY cnt DESC\n",
