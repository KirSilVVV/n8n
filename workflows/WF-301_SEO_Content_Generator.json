        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: 'claude-sonnet-4-6',\n  max_tokens: 1800,\n  system: \"\\u0422\\u044b \\u2014 SEO-\\u044d\\u043a\\u0441\\u043f\\u0435\\u0440\\u0442 \\u0434\\u043b\\u044f \\u0440\\u043e\\u0441\\u0441\\u0438\\u0439\\u0441\\u043a\\u043e\\u0433\\u043e \\u043c\\u0430\\u0440\\u043a\\u0435\\u0442\\u043f\\u043b\\u0435\\u0439\\u0441\\u0430 \\u0446\\u0438\\u0444\\u0440\\u043e\\u0432\\u044b\\u0445 \\u0442\\u043e\\u0432\\u0430\\u0440\\u043e\\u0432 \\u00ab\\u0413\\u0435\\u0439\\u043c\\u0438\\u043d\\u0433 \\u0413\\u0443\\u0434\\u0441\\u00bb (gaming-goods.ru). \\u041f\\u0438\\u0448\\u0435\\u0448\\u044c \\u0434\\u043b\\u044f \\u042f\\u043d\\u0434\\u0435\\u043a\\u0441\\u0430 \\u0438 Google \\u0420\\u0424.\\n\\n\\u0424\\u041e\\u0420\\u041c\\u0410\\u0422 \\u041e\\u0422\\u0412\\u0415\\u0422\\u0410 \\u2014 \\u0441\\u0442\\u0440\\u043e\\u0433\\u043e JSON \\u0431\\u0435\\u0437 markdown \\u0438 \\u043f\\u043e\\u044f\\u0441\\u043d\\u0435\\u043d\\u0438\\u0439:\\n{\\\"title\\\":\\\"...\\\",\\\"description\\\":\\\"...\\\",\\\"h1\\\":\\\"...\\\",\\\"article\\\":\\\"...\\\",\\\"faq\\\":[{\\\"question\\\":\\\"...\\\",\\\"answer\\\":\\\"...\\\"},{\\\"question\\\":\\\"...\\\",\\\"answer\\\":\\\"...\\\"},{\\\"question\\\":\\\"...\\\",\\\"answer\\\":\\\"...\\\"}],\\\"related_queries\\\":\\\"...\\\"}\\n\\n\\u0422\\u0420\\u0415\\u0411\\u041e\\u0412\\u0410\\u041d\\u0418\\u042f \\u041a \\u041a\\u0410\\u0416\\u0414\\u041e\\u041c\\u0423 \\u041f\\u041e\\u041b\\u042e:\\n\\ntitle (55-65 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432):\\n- \\u0421\\u043e\\u0434\\u0435\\u0440\\u0436\\u0438\\u0442 \\u0433\\u043b\\u0430\\u0432\\u043d\\u044b\\u0439 \\u043a\\u043b\\u044e\\u0447\\u0435\\u0432\\u043e\\u0439 \\u0437\\u0430\\u043f\\u0440\\u043e\\u0441 (\\u043d\\u0430\\u0437\\u0432\\u0430\\u043d\\u0438\\u0435 \\u0442\\u043e\\u0432\\u0430\\u0440\\u0430 + \\\"\\u043a\\u0443\\u043f\\u0438\\u0442\\u044c\\\")\\n- \\u0423\\u043d\\u0438\\u043a\\u0430\\u043b\\u044c\\u043d\\u0430\\u044f \\u043a\\u043e\\u043d\\u0441\\u0442\\u0440\\u0443\\u043a\\u0446\\u0438\\u044f \\u2014 \\u041d\\u0415 \\u0448\\u0430\\u0431\\u043b\\u043e\\u043d, \\u043a\\u0430\\u0436\\u0434\\u044b\\u0439 \\u0440\\u0430\\u0437 \\u0440\\u0430\\u0437\\u043d\\u0430\\u044f \\u0444\\u043e\\u0440\\u043c\\u0443\\u043b\\u0438\\u0440\\u043e\\u0432\\u043a\\u0430\\n- \\u0412\\u0430\\u0440\\u0438\\u0430\\u043d\\u0442\\u044b \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430: \\\"\\u041a\\u0443\\u043f\\u0438\\u0442\\u044c...\\\", \\\"...\\u043a\\u0443\\u043f\\u0438\\u0442\\u044c \\u0432 \\u0413\\u0435\\u0439\\u043c\\u0438\\u043d\\u0433 \\u0413\\u0443\\u0434\\u0441\\\", \\\"...\\u2014 \\u043a\\u0443\\u043f\\u0438\\u0442\\u044c \\u043a\\u043b\\u044e\\u0447/\\u043a\\u0430\\u0440\\u0442\\u0443\\\"\\n- \\u041e\\u0431\\u044f\\u0437\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e: \\u043f\\u043b\\u0430\\u0442\\u0444\\u043e\\u0440\\u043c\\u0430 \\u0438\\u043b\\u0438 \\u043d\\u043e\\u043c\\u0438\\u043d\\u0430\\u043b \\u0435\\u0441\\u043b\\u0438 \\u0435\\u0441\\u0442\\u044c \\u0432 \\u0431\\u0440\\u0435\\u043d\\u0434\\u0435/\\u043a\\u0430\\u0442\\u0435\\u0433\\u043e\\u0440\\u0438\\u0438\\n\\ndescription (145-160 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432):\\n- \\u0416\\u0438\\u0432\\u043e\\u0435 \\u043f\\u0440\\u043e\\u0434\\u0430\\u044e\\u0449\\u0435\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435 \\u0441 \\u043a\\u043e\\u043d\\u043a\\u0440\\u0435\\u0442\\u0438\\u043a\\u043e\\u0439\\n- \\u0423\\u043f\\u043e\\u043c\\u0438\\u043d\\u0430\\u0435\\u0442: \\u0441\\u043f\\u043e\\u0441\\u043e\\u0431 \\u0434\\u043e\\u0441\\u0442\\u0430\\u0432\\u043a\\u0438 (\\u043c\\u0433\\u043d\\u043e\\u0432\\u0435\\u043d\\u043d\\u043e/email), \\u0433\\u0430\\u0440\\u0430\\u043d\\u0442\\u0438\\u044e, \\u00ab\\u0413\\u0435\\u0439\\u043c\\u0438\\u043d\\u0433 \\u0413\\u0443\\u0434\\u0441\\u00bb\\n- \\u0418\\u0437\\u0431\\u0435\\u0433\\u0430\\u0442\\u044c: \\\"\\u043b\\u0443\\u0447\\u0448\\u0438\\u0439\\\", \\\"\\u043e\\u0433\\u0440\\u043e\\u043c\\u043d\\u044b\\u0439 \\u0432\\u044b\\u0431\\u043e\\u0440\\\" \\u2014 \\u043f\\u0438\\u0448\\u0435\\u043c \\u043a\\u043e\\u043d\\u043a\\u0440\\u0435\\u0442\\u043d\\u043e\\n\\nh1 (30-65 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432):\\n- \\u0411\\u0435\\u0437 \\u0441\\u043b\\u043e\\u0432\\u0430 \\\"\\u043a\\u0443\\u043f\\u0438\\u0442\\u044c\\\", \\u043e\\u043f\\u0438\\u0441\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u044b\\u0439 \\u0437\\u0430\\u0433\\u043e\\u043b\\u043e\\u0432\\u043e\\u043a\\n- \\u0421\\u043e\\u0434\\u0435\\u0440\\u0436\\u0438\\u0442 \\u0431\\u0440\\u0435\\u043d\\u0434 + \\u0442\\u0438\\u043f \\u0442\\u043e\\u0432\\u0430\\u0440\\u0430 + \\u043a\\u043b\\u044e\\u0447\\u0435\\u0432\\u043e\\u0439 \\u0430\\u0442\\u0440\\u0438\\u0431\\u0443\\u0442 (\\u043f\\u043b\\u0430\\u0442\\u0444\\u043e\\u0440\\u043c\\u0430/\\u043d\\u043e\\u043c\\u0438\\u043d\\u0430\\u043b/\\u0442\\u0438\\u043f)\\n\\narticle (400-550 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432):\\n- \\u0410\\u0431\\u0437\\u0430\\u0446 \\u0441 \\u0441\\u0435\\u043c\\u0430\\u043d\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u043c \\u0431\\u043e\\u0433\\u0430\\u0442\\u0441\\u0442\\u0432\\u043e\\u043c: \\u0441\\u0438\\u043d\\u043e\\u043d\\u0438\\u043c\\u044b, LSI-\\u0437\\u0430\\u043f\\u0440\\u043e\\u0441\\u044b, \\u0440\\u0430\\u0437\\u0433\\u043e\\u0432\\u043e\\u0440\\u043d\\u044b\\u0435 \\u0432\\u0430\\u0440\\u0438\\u0430\\u043d\\u0442\\u044b\\n- \\u0421\\u0442\\u0440\\u0443\\u043a\\u0442\\u0443\\u0440\\u0430: (1) \\u0447\\u0442\\u043e \\u044d\\u0442\\u043e \\u0437\\u0430 \\u0442\\u043e\\u0432\\u0430\\u0440 \\u0438 \\u0437\\u0430\\u0447\\u0435\\u043c \\u043d\\u0443\\u0436\\u0435\\u043d, (2) \\u0434\\u043b\\u044f \\u043a\\u043e\\u0433\\u043e/\\u043a\\u0430\\u043a\\u0438\\u0445 \\u043f\\u043b\\u0430\\u0442\\u0444\\u043e\\u0440\\u043c, (3) \\u043f\\u043e\\u0447\\u0435\\u043c\\u0443 \\u043d\\u0430 \\u0413\\u0435\\u0439\\u043c\\u0438\\u043d\\u0433 \\u0413\\u0443\\u0434\\u0441\\n- \\u0418\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0439 \\u0412\\u0421\\u0415 \\u0440\\u0435\\u043b\\u0435\\u0432\\u0430\\u043d\\u0442\\u043d\\u044b\\u0435 \\u0442\\u0435\\u0440\\u043c\\u0438\\u043d\\u044b: \\u0430\\u043b\\u044c\\u0442\\u0435\\u0440\\u043d\\u0430\\u0442\\u0438\\u0432\\u043d\\u044b\\u0435 \\u043d\\u0430\\u0437\\u0432\\u0430\\u043d\\u0438\\u044f, \\u043f\\u043e\\u043f\\u0443\\u043b\\u044f\\u0440\\u043d\\u044b\\u0435 \\u0437\\u0430\\u043f\\u0440\\u043e\\u0441\\u044b \\u0432 \\u043d\\u0438\\u0448\\u0435\\n- \\u041f\\u0440\\u0438\\u043c\\u0435\\u0440 \\u0434\\u043b\\u044f Steam Wallet: \\u0443\\u043f\\u043e\\u043c\\u044f\\u043d\\u0438 \\\"\\u043f\\u043e\\u043f\\u043e\\u043b\\u043d\\u0435\\u043d\\u0438\\u0435 Steam\\\", \\\"\\u0431\\u0430\\u043b\\u0430\\u043d\\u0441 Steam\\\", \\\"Steam \\u0434\\u0435\\u043d\\u044c\\u0433\\u0438\\\", \\\"steam \\u043a\\u0430\\u0440\\u0442\\u0430\\\"\\n- \\u041a\\u043e\\u043d\\u043a\\u0440\\u0435\\u0442\\u043d\\u044b\\u0435 \\u0434\\u0435\\u0442\\u0430\\u043b\\u0438: \\u043f\\u043b\\u0430\\u0442\\u0444\\u043e\\u0440\\u043c\\u044b, \\u0440\\u0435\\u0433\\u0438\\u043e\\u043d\\u044b, \\u0441\\u043f\\u043e\\u0441\\u043e\\u0431 \\u0430\\u043a\\u0442\\u0438\\u0432\\u0430\\u0446\\u0438\\u0438\\n- \\u041d\\u0435 \\u043f\\u043e\\u0432\\u0442\\u043e\\u0440\\u044f\\u0439 \\u0444\\u0440\\u0430\\u0437\\u044b \\u0438\\u0437 title/description \\u0434\\u043e\\u0441\\u043b\\u043e\\u0432\\u043d\\u043e\\n\\nfaq \\u2014 3 \\u0432\\u043e\\u043f\\u0440\\u043e\\u0441\\u0430:\\n- \\u0412\\u043e\\u043f\\u0440\\u043e\\u0441 1: \\u043f\\u0440\\u0430\\u043a\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0439 (\\u043a\\u0430\\u043a \\u0430\\u043a\\u0442\\u0438\\u0432\\u0438\\u0440\\u043e\\u0432\\u0430\\u0442\\u044c/\\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c) \\u2014 \\u0441 \\u043a\\u043e\\u043d\\u043a\\u0440\\u0435\\u0442\\u043d\\u044b\\u043c\\u0438 \\u0448\\u0430\\u0433\\u0430\\u043c\\u0438\\n- \\u0412\\u043e\\u043f\\u0440\\u043e\\u0441 2: \\u043f\\u0440\\u043e \\u0441\\u043e\\u0432\\u043c\\u0435\\u0441\\u0442\\u0438\\u043c\\u043e\\u0441\\u0442\\u044c/\\u0440\\u0435\\u0433\\u0438\\u043e\\u043d (\\u0440\\u0430\\u0431\\u043e\\u0442\\u0430\\u0435\\u0442 \\u043b\\u0438 \\u0438\\u0437 \\u0420\\u043e\\u0441\\u0441\\u0438\\u0438 / \\u0434\\u043b\\u044f \\u043a\\u0430\\u043a\\u0438\\u0445 \\u043f\\u043b\\u0430\\u0442\\u0444\\u043e\\u0440\\u043c)\\n- \\u0412\\u043e\\u043f\\u0440\\u043e\\u0441 3: \\u043f\\u0440\\u043e \\u0434\\u043e\\u0441\\u0442\\u0430\\u0432\\u043a\\u0443 \\u0438\\u043b\\u0438 \\u043e\\u0441\\u043e\\u0431\\u0435\\u043d\\u043d\\u043e\\u0441\\u0442\\u0438 \\u0442\\u043e\\u0432\\u0430\\u0440\\u0430\\n- \\u041e\\u0442\\u0432\\u0435\\u0442\\u044b: 2-3 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u044f, \\u043a\\u043e\\u043d\\u043a\\u0440\\u0435\\u0442\\u043d\\u044b\\u0435, \\u0441 \\u0434\\u0435\\u0442\\u0430\\u043b\\u044f\\u043c\\u0438\\n\\nrelated_queries (\\u0441\\u0442\\u0440\\u043e\\u043a\\u0430 \\u0447\\u0435\\u0440\\u0435\\u0437 \\u0437\\u0430\\u043f\\u044f\\u0442\\u0443\\u044e):\\n- 5-8 \\u0440\\u0435\\u0430\\u043b\\u044c\\u043d\\u044b\\u0445 \\u043f\\u043e\\u0438\\u0441\\u043a\\u043e\\u0432\\u044b\\u0445 \\u0437\\u0430\\u043f\\u0440\\u043e\\u0441\\u043e\\u0432 \\u043f\\u043e \\u0442\\u0435\\u043c\\u0435 \\u043d\\u0430 \\u0440\\u0443\\u0441\\u0441\\u043a\\u043e\\u043c\\n- \\u0414\\u043b\\u0438\\u043d\\u043d\\u043e\\u0445\\u0432\\u043e\\u0441\\u0442\\u044b\\u0435 \\u0437\\u0430\\u043f\\u0440\\u043e\\u0441\\u044b: \\\"\\u043a\\u0443\\u043f\\u0438\\u0442\\u044c [\\u0431\\u0440\\u0435\\u043d\\u0434] \\u0434\\u0451\\u0448\\u0435\\u0432\\u043e\\\", \\\"[\\u0431\\u0440\\u0435\\u043d\\u0434] \\u043a\\u043b\\u044e\\u0447 ru\\\", \\\"[\\u0431\\u0440\\u0435\\u043d\\u0434] \\u0431\\u0435\\u0437 \\u0438\\u043d\\u043e\\u0441\\u0442\\u0440\\u0430\\u043d\\u043d\\u043e\\u0439 \\u043a\\u0430\\u0440\\u0442\\u044b\\\"\\n- \\u041e\\u043d\\u0438 \\u0441\\u0442\\u0430\\u043d\\u0443\\u0442 \\u0431\\u0430\\u0437\\u043e\\u0439 \\u0434\\u043b\\u044f \\u0432\\u043d\\u0443\\u0442\\u0440\\u0435\\u043d\\u043d\\u0435\\u0439 \\u043f\\u0435\\u0440\\u0435\\u043b\\u0438\\u043d\\u043a\\u043e\\u0432\\u043a\\u0438\",\n  messages: [{\n    role: 'user',\n    content: `Бренд: ${$json.brand}\\nКатегория: ${$json.category}\\nURL: ${$json.url}\\n\\nНапиши SEO-контент для этой страницы. Учитывай специфику бренда и категории товара.`\n  }]\n}) }}",
        "options": {
          "batching": {
            "batch": {
              "batchSize": 1,
              "batchInterval": 1500
            }
          },
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "parse",
      "name": "Parse Claude response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst claudeItems = $input.all();\nconst pgItems = $('PG: Pages without article or faq').all();\nconst results = [];\n\nfor (let i = 0; i < claudeItems.length; i++) {\n  const resp = claudeItems[i].json;\n  const pg = pgItems[i] ? pgItems[i].json : {};\n  const url = pg.url || '';\n\n  if (resp.error) {\n    results.push({ json: { ok: 'false', url, error: (resp.error.message||'api error').slice(0,80) } });\n    continue;\n  }\n\n  try {\n    let text = (resp.content || [])[0]?.text || '';\n    text = text.replace(/```json\\n?/gi,'').replace(/```\\n?/g,'').trim();\n    const d = JSON.parse(text);\n\n    // Escape single quotes for PostgreSQL\n    const esc = s => (s || '').replace(/'/g, \"''\").trim();\n\n    // Validate FAQ format: must be [{question, answer}, ...]\n    let faqJson = '[]';\n    if (Array.isArray(d.faq) && d.faq.length >= 3) {\n      const validFaq = d.faq\n        .filter(f => f.question && f.answer)\n        .map(f => ({ question: esc(f.question), answer: esc(f.answer) }));\n      if (validFaq.length >= 3) {\n        faqJson = JSON.stringify(validFaq);\n      }\n    }\n\n    // Validate lengths\n    const title = esc(d.title || '');\n    const description = esc(d.description || '');\n    const h1 = esc(d.h1 || '');\n    const article = esc(d.article || '');\n    const keywords = esc(d.keywords || '');\n\n    const ok = title.length >= 30 && description.length >= 100 ? 'true' : 'false';\n\n    results.push({ json: {\n      ok,\n      url,\n      title,\n      description,\n      h1,\n      article,\n      faq: faqJson,\n      keywords,\n      title_len: title.length,\n      desc_len: description.length,\n      article_len: article.length,\n      faq_count: d.faq ? d.faq.length : 0\n    }});\n\n  } catch(e) {\n    results.push({ json: { ok: 'false', url, error: ('parse_error: ' + e.message).slice(0,80) } });\n  }\n}\n\nreturn results;\n"
      }
    },
    {
