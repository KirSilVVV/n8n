      {
        "parameters": {
          "jsCode": "\nconst claudeItems = $input.all();\nconst pgItems = $('PG: Pages without article or faq').all();\nconst results = [];\n\nfunction escapeSql(s) {\n  return (s || '').replace(/'/g, \"''\");\n}\n\nfor (let i = 0; i < claudeItems.length; i++) {\n  const resp = claudeItems[i].json;\n  const pg = pgItems[i] ? pgItems[i].json : {};\n  const url = pg.url || '';\n\n  if (resp.error) {\n    results.push({ json: { ok: 'false', url, error: (resp.error.message||'api error').slice(0,80) } });\n    continue;\n  }\n\n  try {\n    let text = (resp.content || [])[0]?.text || '';\n    text = text.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/\\s*```$/i, '').trim();\n    const start = text.indexOf('{');\n    const end = text.lastIndexOf('}');\n    if (start !== -1 && end !== -1 && end > start) {\n      text = text.slice(start, end + 1);\n    }\n    \n    const seo = JSON.parse(text);\n    const article = (seo.article || '').trim();\n    const faq = Array.isArray(seo.faq) ? seo.faq : [];\n    \n    if (article.length < 200) {\n      results.push({ json: { ok: 'false', url, error: 'article too short: ' + article.length } });\n      continue;\n    }\n    \n    // Экранируем для PostgreSQL\n    results.push({\n      json: {\n        ok: 'true',\n        url: escapeSql(url),\n        title: escapeSql((seo.title || '').slice(0, 200)),\n        description: escapeSql((seo.description || '').slice(0, 500)),\n        h1: escapeSql((seo.h1 || '').slice(0, 200)),\n        article: escapeSql(article),\n        faq: escapeSql(JSON.stringify(faq)),\n        url_raw: url\n      }\n    });\n  } catch(e) {\n    results.push({ json: { ok: 'false', url, error: ('parse: ' + e.message).slice(0,80) } });\n  }\n}\n\nreturn results;\n"
        },
