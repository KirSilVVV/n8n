    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT ps.url, ps.title,\n  TRIM(split_part(split_part(coalesce(ps.title,''),' купить',1),' |',1)) as brand,\n  CASE WHEN ps.url LIKE '%-gift-card' THEN 'Gift Card'\n       WHEN ps.url LIKE '%-currency' THEN 'Currency'\n       WHEN ps.url LIKE '%-game-keys' THEN 'Game Keys'\n       WHEN ps.url LIKE '%-accounts' THEN 'Accounts'\n       WHEN ps.url LIKE '%-subscription' THEN 'Subscription'\n       ELSE 'Other' END as category\nFROM page_seo ps\nWHERE ps.lang='ru' AND ps.url LIKE '%/t/%'\n  AND ps.title IS NOT NULL AND length(ps.title) > 5\n  AND (\n    ps.article IS NULL OR length(ps.article) < 380\n    OR ps.faq IS NULL OR jsonb_array_length(ps.faq) < 3\n  )\nORDER BY\n  CASE WHEN ps.url LIKE '%nutaku%' THEN 1\n       WHEN ps.url LIKE '%telegram%' THEN 2\n       WHEN ps.url LIKE '%steam%' THEN 3\n       WHEN ps.url LIKE '%roblox%' THEN 4\n       WHEN ps.url LIKE '%minecraft%' THEN 5\n       WHEN ps.url LIKE '%pubg%' THEN 6\n       WHEN ps.url LIKE '%genshin%' THEN 7\n       WHEN ps.url LIKE '%xbox%' THEN 8\n       WHEN ps.url LIKE '%playstation%' THEN 9\n       ELSE 99 END,\n  CASE WHEN ps.url LIKE '%-gift-card' THEN 1\n       WHEN ps.url LIKE '%-currency' THEN 2\n       WHEN ps.url LIKE '%-game-keys' THEN 3\n       WHEN ps.url LIKE '%-subscription' THEN 4\n       ELSE 5 END,\n  ps.url\nLIMIT 2000",
        "options": {}
      },
