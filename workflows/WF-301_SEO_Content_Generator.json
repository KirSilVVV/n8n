    {
      "parameters": {
        "jsCode": "\nconst all = $input.all();\nconst ok = all.filter(i => i.json.id).length;\nconst total = all.length;\nconst errs = all.filter(i => !i.json.id && i.json.url).slice(0,3);\nconst date = new Date().toISOString().slice(0,10);\nlet msg = '✍️ WF-301 SEO Content\\n\\n';\nmsg += '✅ Записано: ' + ok + ' / ' + total + ' страниц\\n';\nif (errs.length) msg += '⚠️ Ошибок: ' + errs.length + '\\n  ' + errs.map(e=>e.json.error||'no id').join(', ').slice(0,100) + '\\n';\nmsg += '📅 ' + date;\nreturn [{ json: { msg } }];\n"
      },
