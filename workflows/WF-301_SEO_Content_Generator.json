        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: 'claude-haiku-4-5-20251001',\n  max_tokens: 900,\n  system: \"\\u0422\\u044b \\u2014 SEO-\\u0441\\u043f\\u0435\\u0446\\u0438\\u0430\\u043b\\u0438\\u0441\\u0442 \\u0434\\u043b\\u044f \\u043c\\u0430\\u0440\\u043a\\u0435\\u0442\\u043f\\u043b\\u0435\\u0439\\u0441\\u0430 \\u0446\\u0438\\u0444\\u0440\\u043e\\u0432\\u044b\\u0445 \\u0442\\u043e\\u0432\\u0430\\u0440\\u043e\\u0432 \\\"\\u0413\\u0435\\u0439\\u043c\\u0438\\u043d\\u0433 \\u0413\\u0443\\u0434\\u0441\\\". \\u0413\\u0435\\u043d\\u0435\\u0440\\u0438\\u0440\\u0443\\u0439 \\u0443\\u043d\\u0438\\u043a\\u0430\\u043b\\u044c\\u043d\\u044b\\u0435 SEO-\\u0434\\u0430\\u043d\\u043d\\u044b\\u0435.\\n\\u0412\\u0435\\u0440\\u043d\\u0438 \\u0441\\u0442\\u0440\\u043e\\u0433\\u043e JSON \\u0431\\u0435\\u0437 markdown:\\n{\\\"title\\\":\\\"...\\\",\\\"description\\\":\\\"...\\\",\\\"h1\\\":\\\"...\\\",\\\"article\\\":\\\"...\\\",\\\"faq\\\":[{\\\"question\\\":\\\"...\\\",\\\"answer\\\":\\\"...\\\"},{\\\"question\\\":\\\"...\\\",\\\"answer\\\":\\\"...\\\"},{\\\"question\\\":\\\"...\\\",\\\"answer\\\":\\\"...\\\"}],\\\"keywords\\\":\\\"...\\\"}\\n\\n\\u0422\\u0440\\u0435\\u0431\\u043e\\u0432\\u0430\\u043d\\u0438\\u044f:\\ntitle: 50-60 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432, \\u0441\\u043e\\u0434\\u0435\\u0440\\u0436\\u0438\\u0442 \\\"\\u043a\\u0443\\u043f\\u0438\\u0442\\u044c\\\", \\u0443\\u043d\\u0438\\u043a\\u0430\\u043b\\u044c\\u043d\\u0430\\u044f \\u043a\\u043e\\u043d\\u0441\\u0442\\u0440\\u0443\\u043a\\u0446\\u0438\\u044f \\u043a\\u0430\\u0436\\u0434\\u044b\\u0439 \\u0440\\u0430\\u0437.\\ndescription: 140-160 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432, \\u0436\\u0438\\u0432\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435, \\u043a\\u043e\\u043d\\u043a\\u0440\\u0435\\u0442\\u0438\\u043a\\u0430 \\u0441 \\u0446\\u0435\\u043d\\u043e\\u0439, \\\"\\u0413\\u0435\\u0439\\u043c\\u0438\\u043d\\u0433 \\u0413\\u0443\\u0434\\u0441\\\".\\nh1: 20-60 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432, \\u0431\\u0435\\u0437 \\u0441\\u043b\\u043e\\u0432\\u0430 \\\"\\u043a\\u0443\\u043f\\u0438\\u0442\\u044c\\\", \\u043e\\u043f\\u0438\\u0441\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u044b\\u0439.\\narticle: 200-280 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u043e\\u0432, \\u0443\\u043d\\u0438\\u043a\\u0430\\u043b\\u044c\\u043d\\u044b\\u0439 \\u0432\\u0438\\u0434\\u0438\\u043c\\u044b\\u0439 \\u0442\\u0435\\u043a\\u0441\\u0442 \\u043e \\u0442\\u043e\\u0432\\u0430\\u0440\\u0435 \\u2014 \\u0447\\u0442\\u043e \\u044d\\u0442\\u043e, \\u0437\\u0430\\u0447\\u0435\\u043c \\u043d\\u0443\\u0436\\u043d\\u043e, \\u043f\\u043e\\u0447\\u0435\\u043c\\u0443 \\u043a\\u0443\\u043f\\u0438\\u0442\\u044c \\u0437\\u0434\\u0435\\u0441\\u044c. \\u041d\\u0435 \\u0448\\u0430\\u0431\\u043b\\u043e\\u043d!\\nfaq: \\u0440\\u043e\\u0432\\u043d\\u043e 3 \\u0432\\u043e\\u043f\\u0440\\u043e\\u0441\\u0430 \\u0432 \\u0444\\u043e\\u0440\\u043c\\u0430\\u0442\\u0435 question/answer. \\u0414\\u043b\\u044f game-keys: \\u0430\\u043a\\u0442\\u0438\\u0432\\u0430\\u0446\\u0438\\u044f, \\u0440\\u0430\\u0431\\u043e\\u0442\\u0430 \\u0432 \\u0420\\u0424, \\u0434\\u043e\\u0441\\u0442\\u0430\\u0432\\u043a\\u0430. \\u0414\\u043b\\u044f gift-card: \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u043d\\u0438\\u0435, \\u0434\\u043e\\u0441\\u0442\\u0430\\u0432\\u043a\\u0430, \\u0441\\u043f\\u043e\\u0441\\u043e\\u0431\\u044b \\u043e\\u043f\\u043b\\u0430\\u0442\\u044b. \\u0414\\u043b\\u044f currency: \\u0437\\u0430\\u0447\\u0438\\u0441\\u043b\\u0435\\u043d\\u0438\\u0435, \\u043f\\u043b\\u0430\\u0442\\u0444\\u043e\\u0440\\u043c\\u0430, \\u043f\\u043e\\u0434\\u0434\\u0435\\u0440\\u0436\\u043a\\u0430.\\nkeywords: 3-5 \\u043a\\u043b\\u044e\\u0447\\u0435\\u0432\\u044b\\u0445 \\u0441\\u043b\\u043e\\u0432\\u0430 \\u0447\\u0435\\u0440\\u0435\\u0437 \\u0437\\u0430\\u043f\\u044f\\u0442\\u0443\\u044e.\",\n  messages: [{\n    role: 'user',\n    content: 'Товар: ' + $json.brand + '\\nКатегория: ' + $json.category + '\\nURL: ' + $json.url\n  }]\n}) }}",
