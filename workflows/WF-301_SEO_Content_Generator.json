      {
        "id": "parse",
        "name": "Parse Claude response",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          800,
          300
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "jsCode": "\nconst claudeItems = $input.all();\nconst pgItems = $('PG: Pages without article or faq').all();\nconst results = [];\n\nfor (let i = 0; i < claudeItems.length; i++) {\n  const resp = claudeItems[i].json;\n  const pg = pgItems[i] ? pgItems[i].json : {};\n  const url = pg.url || '';\n\n  if (resp.error) {\n    results.push({ json: { ok: 'false', url, error: (resp.error.message||'api error').slice(0,80) } });\n    continue;\n  }\n\n  try {\n    let text = (resp.content || [])[0]?.text || '';\n    text = text.replace(/```json\\n?/gi,'').replace(/```\\n?/g,'').trim();\n    const d = JSON.parse(text);\n\n    // Escape single quotes for PostgreSQL\n    const esc = s => (s || '').replace(/'/g, \"''\").trim();\n\n    // Validate FAQ format: must be [{question, answer}, ...]\n    let faqJson = '[]';\n    if (Array.isArray(d.faq) && d.faq.length >= 3) {\n      const validFaq = d.faq\n        .filter(f => f.question && f.answer)\n        .map(f => ({ question: esc(f.question), answer: esc(f.answer) }));\n      if (validFaq.length >= 3) {\n        faqJson = JSON.stringify(validFaq);\n      }\n    }\n\n    // Validate lengths\n    const title = esc(d.title || '');\n    const description = esc(d.description || '');\n    const h1 = esc(d.h1 || '');\n    const article = esc(d.article || '');\n    const keywords = esc(d.keywords || '');\n\n    const ok = title.length >= 30 && description.length >= 100 ? 'true' : 'false';\n\n    results.push({ json: {\n      ok,\n      url,\n      title,\n      description,\n      h1,\n      article,\n      faq: faqJson,\n      keywords,\n      title_len: title.length,\n      desc_len: description.length,\n      article_len: article.length,\n      faq_count: d.faq ? d.faq.length : 0\n    }});\n\n  } catch(e) {\n    results.push({ json: { ok: 'false', url, error: ('parse_error: ' + e.message).slice(0,80) } });\n  }\n}\n\nreturn results;\n"
        }
      },
