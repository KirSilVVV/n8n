    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nSELECT\n  order_data->>'productId' as od_product_id,\n  content->'items'->0->>'id' as content_item_id,\n  content->'items'->0->>'brand' as content_brand,\n  LEFT(content->'items'->0->>'title', 50) as content_title,\n  status,\n  external_order_id\nFROM marketplace_order\nWHERE status IN ('completed','completed_with_review')\n  AND created_at > NOW() - INTERVAL '14 days'\nLIMIT 8\n",
